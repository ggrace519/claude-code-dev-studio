# Normalize line endings in the repo; per-platform on checkout.
* text=auto

# Shell scripts must have LF everywhere (Git Bash + real *nix shells).
*.sh text eol=lf

# PowerShell scripts: let autocrlf handle checkout. PS 5.1 and 7+ tolerate both.
*.ps1 text

# Markdown / JSON: text, autocrlf-handled.
*.md text
*.json text

# Binary defensive markers (no binaries currently in repo).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
